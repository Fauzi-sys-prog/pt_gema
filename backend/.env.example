NODE_ENV=production
PORT=3000
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_strong_db_password
POSTGRES_DB=gemadb
DATABASE_URL="postgresql://postgres:replace_with_strong_db_password@postgres:5432/gemadb"

# Use at least 32 chars, high entropy, and never commit real value.
JWT_SECRET=replace_with_long_random_secret_min_32_chars
JWT_EXPIRES_IN=8h
API_BODY_LIMIT=15mb
JWT_ISSUER=ptgema-api
JWT_AUDIENCE=ptgema-client
UPLOAD_DIR=uploads
FILE_PUBLIC_BASE_URL=https://api.gemateknik.online

# Comma separated allowed frontend origins in production.
# Example: https://erp.yourcompany.com,https://admin.yourcompany.com
CORS_ORIGIN=https://gemateknik.online

# Set true only for local production-like smoke tests on localhost.
ALLOW_LOCALHOST_CORS_IN_PROD=false
