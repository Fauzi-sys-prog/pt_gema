NODE_ENV=production
PORT=3000

# Postgres credentials for the production docker network.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_real_strong_db_password
POSTGRES_DB=gemadb
DATABASE_URL="postgresql://postgres:replace_with_real_strong_db_password@postgres:5432/gemadb"

# Must be a long random secret, minimum 32 chars.
JWT_SECRET=replace_with_long_random_production_jwt_secret
JWT_EXPIRES_IN=8h
JWT_ISSUER=ptgema-api
JWT_AUDIENCE=ptgema-client

API_BODY_LIMIT=15mb

# Frontend origins allowed to call the API in production.
CORS_ORIGIN=https://gemateknik.online
ALLOW_LOCALHOST_CORS_IN_PROD=false

# Public file base URL exposed behind the production reverse proxy.
UPLOAD_DIR=uploads
FILE_PUBLIC_BASE_URL=https://api.gemateknik.online
