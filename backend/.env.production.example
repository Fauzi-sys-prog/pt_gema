NODE_ENV=production
PORT=3000

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=gemadb
DATABASE_URL="postgresql://postgres:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/gemadb"

# JWT
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=8h
JWT_ISSUER=ptgema-api
JWT_AUDIENCE=ptgema-client
API_BODY_LIMIT=15mb
UPLOAD_DIR=uploads
FILE_PUBLIC_BASE_URL=https://erp.yourcompany.com

# CORS (comma-separated if multiple)
CORS_ORIGIN=https://erp.yourcompany.com
