generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  SPV
  ADMIN
  MANAGER
  HR
  PURCHASING
  USER
  PRODUKSI
  SALES
  FINANCE
  SUPPLY_CHAIN
  WAREHOUSE
  OPERATIONS
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  username String  @unique
  name     String?
  phone    String?
  password String
  role     Role
  isActive Boolean @default(true)
  lastLoginAt DateTime?
  appSettings AppSettingRecord[]
  auditLogEntries AuditLogEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppEntity {
  id        String   @id @default(uuid())
  resource  String
  entityId  String
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([resource, entityId])
  @@index([resource])
}

model Quotation {
  id               String          @id
  noPenawaran      String?
  tanggal          String?
  status           String?
  kepada           String?
  perihal          String?
  grandTotal       Float?
  dataCollectionId String?
  dataCollection   DataCollection? @relation(fields: [dataCollectionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  projects         ProjectRecord[]
  payload          Json
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([status])
  @@index([dataCollectionId])
  @@index([updatedAt])
}

model DataCollection {
  id            String      @id
  namaResponden String?
  lokasi        String?
  tipePekerjaan String?
  status        String?
  tanggalSurvey String?
  payload       Json
  quotations    Quotation[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([status])
  @@index([updatedAt])
}

model ProjectRecord {
  id                   String                      @id
  quotationId          String?
  customerId           String?
  payload              Json
  quotation            Quotation?                  @relation(fields: [quotationId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  customer             CustomerRecord?             @relation(fields: [customerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  purchaseOrders       PurchaseOrderRecord[]
  receivings           ReceivingRecord[]
  workOrders           WorkOrderRecord[]
  productionReports    ProductionReportRecord[]
  productionTrackers   ProductionTrackerRecord[]
  qcInspections        QcInspectionRecord[]
  materialRequests     MaterialRequestRecord[]
  spkRecords           SpkRecord[]
  suratJalan           SuratJalanRecord[]
  beritaAcara          BeritaAcaraRecord[]
  suratMasuk           SuratMasukRecord[]
  suratKeluar          SuratKeluarRecord[]
  invoices             InvoiceRecord[]
  attendances          AttendanceRecord[]
  customerInvoices     CustomerInvoiceRecord[]
  vendorExpenses       VendorExpenseRecord[]
  vendorInvoices       VendorInvoiceRecord[]
  workingExpenseSheets WorkingExpenseSheetRecord[]
  stockMovements       StockMovementRecord[]
  stockIns             StockInRecord[]
  stockOuts            StockOutRecord[]
  assets               AssetRecord[]
  maintenances         MaintenanceRecord[]
  financePoPayments    FinancePoPaymentRecord[]
  financeBankReconciliations FinanceBankReconciliationRecord[]
  financePettyCashTransactions FinancePettyCashTransactionRecord[]
  fleetHealthEntries   FleetHealthEntry[]
  proofsOfDelivery     ProofOfDeliveryRecord[]
  kasbons              KasbonRecord[]
  financeWorkingExpenseSheets FinanceWorkingExpenseSheet[]
  financeBankReconciliationEntries FinanceBankReconciliation[]
  financePettyCashEntries FinancePettyCashTransaction[]
  hrKasbonEntries      HrKasbon[]
  inventoryStockIns    InventoryStockIn[]
  inventoryStockOuts   InventoryStockOut[]
  inventoryMovements   InventoryStockMovement[]
  productionWorkOrders ProductionWorkOrder[]
  productionExecutionReports ProductionExecutionReport[]
  productionTrackerEntries ProductionTrackerEntry[]
  productionQcInspections ProductionQcInspection[]
  productionMaterialRequests ProductionMaterialRequest[]
  logisticsSuratJalan  LogisticsSuratJalan[]
  logisticsProofsOfDelivery LogisticsProofOfDelivery[]
  projectBeritaAcara   ProjectBeritaAcara[]
  projectSpkRecords    ProjectSpkRecord[]
  procurementPurchaseOrders ProcurementPurchaseOrder[]
  procurementReceivings ProcurementReceiving[]
  financeCustomerInvoices FinanceCustomerInvoice[]
  financeVendorExpenses FinanceVendorExpense[]
  financeVendorInvoices FinanceVendorInvoice[]
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  @@index([quotationId])
  @@index([customerId])
  @@index([updatedAt])
}

model RevokedToken {
  id        String   @id @default(uuid())
  jti       String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model ProjectApprovalLog {
  id          String   @id @default(uuid())
  projectId   String
  action      String
  actorUserId String?
  actorRole   Role?
  fromStatus  String?
  toStatus    String?
  reason      String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([action])
}

model QuotationApprovalLog {
  id          String   @id @default(uuid())
  quotationId String
  action      String
  actorUserId String?
  actorRole   Role?
  fromStatus  String?
  toStatus    String?
  reason      String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([quotationId, createdAt])
  @@index([action])
}

model EmployeeRecord {
  id          String             @id
  employeeId  String
  name        String
  identityType String?
  identityNumber String?
  familyStatusCode String?
  gender      String?
  birthDate   String?
  birthPlace  String?
  motherName  String?
  occupationTypeCode String?
  occupationName String?
  alternativeOccupationName String?
  startWorkDate String?
  position    String
  department  String
  employmentType String
  joinDate    String
  endDate     String?
  email       String?
  phone       String?
  address     String?
  emergencyContact String?
  emergencyPhone String?
  salary      Float?
  status      String
  bank        String?
  bankAccount String?
  npwp        String?
  bpjsKesehatan String?
  bpjsKetenagakerjaan String?
  leaveQuota  Float?
  attendances AttendanceRecord[]
  payrolls    PayrollRecord[]
  kasbons     KasbonRecord[]
  financePettyCashTransactions FinancePettyCashTransactionRecord[]
  financePettyCashEntries FinancePettyCashTransaction[]
  hrKasbonEntries HrKasbon[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([employeeId])
  @@index([name])
  @@index([department])
  @@index([status])
}

model AttendanceRecord {
  id           String         @id
  employeeId   String
  projectId    String?
  employeeName String
  date         String
  status       String
  checkIn      String?
  checkOut     String?
  workHours    Float?
  overtime     Float?
  location     String?
  notes        String?
  employee     EmployeeRecord @relation(fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  project      ProjectRecord? @relation(fields: [projectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([employeeId])
  @@index([projectId])
  @@index([date])
  @@index([status])
}

model StockItemRecord {
  id        String   @id
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StockMovementRecord {
  id        String         @id
  projectId String?
  payload   Json
  project   ProjectRecord? @relation(fields: [projectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([projectId])
}

model StockInRecord {
  id        String               @id
  poId      String?
  projectId String?
  payload   Json
  po        PurchaseOrderRecord? @relation(fields: [poId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  project   ProjectRecord?       @relation(fields: [projectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([poId])
  @@index([projectId])
}

model StockOutRecord {
  id          String           @id
  projectId   String?
  workOrderId String?
  payload     Json
  project     ProjectRecord?   @relation(fields: [projectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workOrder   WorkOrderRecord? @relation(fields: [workOrderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([projectId])
  @@index([workOrderId])
}

model StockOpnameRecord {
  id        String   @id
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryItem {
  id                String                   @id
  code              String                   @unique
  name              String
  category          String
  unit              String
  location          String
  minStock          Float                    @default(0)
  onHandQty         Float                    @default(0)
  reservedQty       Float                    @default(0)
  onOrderQty        Float                    @default(0)
  unitPrice         Float?
  supplierName      String?
  status            String?
  lastStockUpdateAt DateTime?
  metadata          Json?
  stockInItems      InventoryStockInItem[]
  stockOutItems     InventoryStockOutItem[]
  movementRows      InventoryStockMovement[]
  opnameItems       InventoryStockOpnameItem[]
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@index([category])
  @@index([location])
  @@index([supplierName])
}

model InventoryStockIn {
  id                String                  @id
  number            String                  @unique
  tanggal           DateTime
  type              String
  status            String
  supplierName      String?
  suratJalanNumber  String?
  notes             String?
  createdByName     String?
  poId              String?
  projectId         String?
  legacyPayload     Json?
  po                PurchaseOrderRecord?    @relation(fields: [poId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  project           ProjectRecord?          @relation(fields: [projectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  items             InventoryStockInItem[]
  movementRows      InventoryStockMovement[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([tanggal])
  @@index([status])
  @@index([poId])
  @@index([projectId])
}

model InventoryStockInItem {
  id              String            @id
  stockInId       String
  inventoryItemId String?
  itemCode        String
  itemName        String
  qty             Float
  unit            String
  batchNo         String?
  expiryDate      DateTime?
  notes           String?
  stockIn         InventoryStockIn  @relation(fields: [stockInId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  inventoryItem   InventoryItem?    @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([stockInId])
  @@index([inventoryItemId])
  @@index([itemCode])
}

model InventoryStockOut {
  id                String                   @id
  number            String                   @unique
  tanggal           DateTime
  type              String
  status            String
  recipientName     String?
  notes             String?
  createdByName     String?
  projectId         String?
  workOrderId       String?
  productionReportId String?
  legacyPayload     Json?
  project           ProjectRecord?           @relation(fields: [projectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workOrder         WorkOrderRecord?         @relation(fields: [workOrderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  items             InventoryStockOutItem[]
  movementRows      InventoryStockMovement[]
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@index([tanggal])
  @@index([status])
  @@index([projectId])
  @@index([workOrderId])
}

model InventoryStockOutItem {
  id              String             @id
  stockOutId      String
  inventoryItemId String?
  itemCode        String
  itemName        String
  qty             Float
  unit            String
  batchNo         String?
  notes           String?
  stockOut        InventoryStockOut  @relation(fields: [stockOutId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  inventoryItem   InventoryItem?     @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([stockOutId])
  @@index([inventoryItemId])
  @@index([itemCode])
}

model InventoryStockMovement {
  id             String              @id
  tanggal        DateTime
  direction      String
  referenceNo    String
  referenceType  String
  inventoryItemId String?
  itemCode       String
  itemName       String
  qty            Float
  unit           String
  location       String
  stockBefore    Float
  stockAfter     Float
  batchNo        String?
  expiryDate     DateTime?
  supplierName   String?
  poNumber       String?
  createdByName  String?
  projectId      String?
  stockInId      String?
  stockOutId     String?
  stockOpnameId  String?
  legacyPayload  Json?
  inventoryItem  InventoryItem?      @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  project        ProjectRecord?      @relation(fields: [projectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  stockIn        InventoryStockIn?   @relation(fields: [stockInId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  stockOut       InventoryStockOut?  @relation(fields: [stockOutId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  stockOpname    InventoryStockOpname? @relation(fields: [stockOpnameId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([tanggal])
  @@index([inventoryItemId])
  @@index([projectId])
  @@index([stockInId])
  @@index([stockOutId])
  @@index([stockOpnameId])
  @@index([referenceNo])
}

model InventoryStockOpname {
  id              String                    @id
  number          String                    @unique
  tanggal         DateTime
  location        String
  status          String
  notes           String?
  createdByName   String?
  confirmedByName String?
  confirmedAt     DateTime?
  legacyPayload   Json?
  items           InventoryStockOpnameItem[]
  movementRows    InventoryStockMovement[]
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([tanggal])
  @@index([location])
  @@index([status])
}

model InventoryStockOpnameItem {
  id              String                @id
  stockOpnameId   String
  inventoryItemId String?
  itemCode        String
  itemName        String
  systemQty       Float
  physicalQty     Float
  differenceQty   Float
  notes           String?
  stockOpname     InventoryStockOpname  @relation(fields: [stockOpnameId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  inventoryItem   InventoryItem?        @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([stockOpnameId])
  @@index([inventoryItemId])
  @@index([itemCode])
}

model InvoiceRecord {
  id         String          @id
  projectId  String?
  customerId String?
  noInvoice  String
  tanggal    String
  jatuhTempo String
  customer   String
  customerName String?
  alamat     String
  noPO       String
  subtotal   Float
  ppn        Float
  totalBayar Float
  paidAmount Float           @default(0)
  outstandingAmount Float    @default(0)
  status     String
  projectName String?
  noFakturPajak String?
  perihal    String?
  termin     String?
  buktiTransfer String?
  noKwitansi String?
  tanggalBayar String?
  project    ProjectRecord?  @relation(fields: [projectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  customerRef CustomerRecord? @relation(fields: [customerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  items      InvoiceItem[]
  bankReconciliations FinanceBankReconciliationRecord[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([projectId])
  @@index([customerId])
  @@index([status])
  @@index([tanggal])
}

model InvoiceItem {
  id          String        @id @default(uuid())
  invoiceId   String
  deskripsi   String
  qty         Float
  unit        String
  hargaSatuan Float
  total       Float
  sourceRef   String?
  batchNo     String?
  invoice     InvoiceRecord @relation(fields: [invoiceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([invoiceId])
}

model PurchaseOrderRecord {
  id              String                   @id
  projectId       String?
  vendorId        String?
  payload         Json
  project         ProjectRecord?           @relation(fields: [projectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  vendor          VendorRecord?            @relation(fields: [vendorId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  receivings      ReceivingRecord[]
  stockIns        StockInRecord[]
  inventoryStockIns InventoryStockIn[]
  financePayments FinancePoPaymentRecord[]
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([projectId])
  @@index([vendorId])
}

model ProcurementPurchaseOrder {
  id              String                     @id
  projectId       String?
  vendorId        String?
  number          String
  tanggal         DateTime
  supplierName    String
  supplierAddress String?
  supplierPhone   String?
  supplierFax     String?
  supplierContact String?
  attention       String?
  notes           String?
  ppnRate         Float                      @default(0)
  topDays         Int                        @default(0)
  ref             String?
  poCode          String?
  deliveryDate    DateTime?
  signatoryName   String?
  totalAmount     Float                      @default(0)
  status          String
  project         ProjectRecord?             @relation(fields: [projectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  vendor          VendorRecord?              @relation(fields: [vendorId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  items           ProcurementPurchaseOrderItem[]
  receivings      ProcurementReceiving[]
  vendorInvoices  FinanceVendorInvoice[]
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  @@index([projectId])
  @@index([vendorId])
  @@index([status])
  @@index([tanggal])
}

model ProcurementPurchaseOrderItem {
  id              String                   @id
  purchaseOrderId String
  itemCode        String?
  itemName        String
  qty             Float                    @default(0)
  unit            String
  unitPrice       Float                    @default(0)
  total           Float                    @default(0)
  qtyReceived     Float                    @default(0)
  source          String?
  sourceRef       String?
  purchaseOrder   ProcurementPurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([purchaseOrderId])
  @@index([itemCode])
}

model ReceivingRecord {
  id        String               @id
  poId      String
  projectId String?
  payload   Json
  po        PurchaseOrderRecord  @relation(fields: [poId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  project   ProjectRecord?       @relation(fields: [projectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([poId])
  @@index([projectId])
}

model ProcurementReceiving {
  id              String                   @id
  purchaseOrderId String
  projectId       String?
  number          String
  suratJalanNo    String?
  suratJalanPhoto String?
  tanggal         DateTime
  purchaseOrderNo String?
  supplierName    String
  projectName     String?
  status          String
  warehouseLocation String?
  notes           String?
  purchaseOrder   ProcurementPurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  project         ProjectRecord?           @relation(fields: [projectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  items           ProcurementReceivingItem[]
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([purchaseOrderId])
  @@index([projectId])
  @@index([status])
  @@index([tanggal])
}

model ProcurementReceivingItem {
  id                String              @id
  receivingId       String
  itemCode          String?
  itemName          String
  qtyOrdered        Float               @default(0)
  qtyReceived       Float               @default(0)
  qtyGood           Float               @default(0)
  qtyDamaged        Float               @default(0)
  qtyPreviouslyReceived Float           @default(0)
  unit              String
  condition         String?
  batchNo           String?
  expiryDate        DateTime?
  photoUrl          String?
  notes             String?
  receiving         ProcurementReceiving @relation(fields: [receivingId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([receivingId])
  @@index([itemCode])
}

model WorkOrderRecord {
  id                 String                    @id
  projectId          String?
  payload            Json
  project            ProjectRecord?            @relation(fields: [projectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  productionReports  ProductionReportRecord[]
  productionTrackers ProductionTrackerRecord[]
  qcInspections      QcInspectionRecord[]
  spkRecords         SpkRecord[]
  stockOuts          StockOutRecord[]
  inventoryStockOuts InventoryStockOut[]
  proofsOfDelivery   ProofOfDeliveryRecord[]
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@index([projectId])
}

model ProductionReportRecord {
  id          String           @id
  projectId   String?
  workOrderId String?
  payload     Json
  project     ProjectRecord?   @relation(fields: [projectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workOrder   WorkOrderRecord? @relation(fields: [workOrderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([projectId])
  @@index([workOrderId])
}

model ProductionTrackerRecord {
  id          String           @id
  projectId   String?
  workOrderId String?
  payload     Json
  project     ProjectRecord?   @relation(fields: [projectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workOrder   WorkOrderRecord? @relation(fields: [workOrderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([projectId])
  @@index([workOrderId])
}

model QcInspectionRecord {
  id          String           @id
  projectId   String?
  workOrderId String?
  payload     Json
  project     ProjectRecord?   @relation(fields: [projectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workOrder   WorkOrderRecord? @relation(fields: [workOrderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([projectId])
  @@index([workOrderId])
}

model MaterialRequestRecord {
  id        String         @id
  projectId String?
  payload   Json
  project   ProjectRecord? @relation(fields: [projectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([projectId])
}

model ProductionWorkOrder {
  id                 String                    @id
  number             String                    @unique
  projectId          String
  projectName        String
  itemToProduce      String
  targetQty          Float
  completedQty       Float                     @default(0)
  status             String
  priority           String
  deadline           DateTime?
  leadTechnician     String
  machineId          String?
  startDate          DateTime?
  endDate            DateTime?
  workflowStatus     String?
  project            ProjectRecord             @relation(fields: [projectId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  machine            AssetRecord?              @relation(fields: [machineId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  bomItems           ProductionWorkOrderBom[]
  productionReports  ProductionExecutionReport[]
  productionTrackers ProductionTrackerEntry[]
  qcInspections      ProductionQcInspection[]
  logisticsProofsOfDelivery LogisticsProofOfDelivery[]
  projectSpkRecords  ProjectSpkRecord[]
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@index([projectId])
  @@index([machineId])
  @@index([status])
  @@index([deadline])
}

model ProductionWorkOrderBom {
  id              String              @id
  workOrderId     String
  itemCode        String?
  itemName        String
  unit            String
  qty             Float
  completedQty    Float               @default(0)
  needsProcurement Boolean            @default(false)
  stockAvailable  Float?
  workOrder       ProductionWorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([workOrderId])
  @@index([itemCode])
}

model ProductionExecutionReport {
  id            String              @id
  projectId     String
  workOrderId   String?
  tanggal       DateTime
  shift         String?
  outputQty     Float               @default(0)
  rejectQty     Float               @default(0)
  efficiency    Float?
  notes         String?
  workerName    String?
  activity      String?
  machineNo     String?
  startTime     String?
  endTime       String?
  unit          String?
  photoUrl      String?
  workflowStatus String?
